    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "firebase": "^12.10.0",
    "form-data": "^4.0.5",
    "ical-generator": "^10.1.0",
    "lucide-react": "^0.546.0",
    "mailgun.js": "^12.7.1",
    "motion": "^12.23.24",
    "node-cron": "^4.2.1",
    "node-ical": "^0.25.6",
    "react": "^19.0.0",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.13.1",
